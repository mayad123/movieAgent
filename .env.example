# =============================================================================
# CineMind — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Required for Real Agent mode (OpenAI-compatible HTTP API, e.g. vLLM / Llama)
# Base URL may be http://127.0.0.1:8000 — /v1 is appended automatically if missing.
# -----------------------------------------------------------------------------
CINEMIND_LLM_BASE_URL=http://127.0.0.1:8000
CINEMIND_LLM_MODEL=meta-llama/Llama-3.3-8B-Instruct
# Optional bearer token if your inference server requires it
CINEMIND_LLM_API_KEY=
CINEMIND_LLM_TIMEOUT_SECONDS=120
# Set true only if your server supports response_format json_object (optional)
CINEMIND_LLM_SUPPORTS_JSON_MODE=false
# Optional: enable semantic cache embeddings via POST .../v1/embeddings (same base URL)
CINEMIND_LLM_EMBEDDING_MODEL=

# -----------------------------------------------------------------------------
# Optional — Enhanced search via Tavily
# -----------------------------------------------------------------------------
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# Recommended — TMDB: enables real movie posters, backdrops, and scenes
# Free account: https://www.themoviedb.org/signup → Settings → API → Request Token
# Takes ~2 minutes. Without it, cards render as styled placeholders (title only).
# -----------------------------------------------------------------------------
TMDB_READ_ACCESS_TOKEN=
ENABLE_TMDB_SCENES=true
# Poster fetch strategy: "fallback_only" (default) or "always"
TMDB_POSTER_MODE=fallback_only

# -----------------------------------------------------------------------------
# Optional — Watchmode (Where to Watch)
# Get an API key at https://watchmode.com
# Server-side only; never exposed to the client.
# -----------------------------------------------------------------------------
WATCHMODE_API_KEY=

# -----------------------------------------------------------------------------
# Prompting
# -----------------------------------------------------------------------------
PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# Kaggle dataset search
# -----------------------------------------------------------------------------
ENABLE_KAGGLE_SEARCH=true
KAGGLE_CORRELATION_THRESHOLD=0.7
KAGGLE_DATASET_PATH=

# -----------------------------------------------------------------------------
# Database (SQLite path or PostgreSQL URL)
# -----------------------------------------------------------------------------
DATABASE_URL=cinemind.db

# -----------------------------------------------------------------------------
# Real Agent safety limits
# -----------------------------------------------------------------------------
CINEMIND_REAL_AGENT_TIMEOUT=90
CINEMIND_REAL_AGENT_MAX_TOKENS=2000
CINEMIND_REAL_AGENT_MAX_TOOL_CALLS=10

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
