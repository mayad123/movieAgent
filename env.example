# CineMind Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenAI API Key for LLM responses
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Tavily API Key for enhanced real-time search
# Get one at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: OpenAI Model to use (default: gpt-3.5-turbo)
# Options: gpt-3.5-turbo, gpt-4, gpt-4o, gpt-4-turbo
# OPENAI_MODEL=gpt-3.5-turbo

